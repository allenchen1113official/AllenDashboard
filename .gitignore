# ── config.js ─────────────────────────────────────────────
# config.js is ignored by default to prevent accidental credential leaks.
#
# For GitHub Pages deployment, GitHub Actions generates config.js
# automatically from repository Secrets (see .github/workflows/deploy.yml).
#
# If you want to commit an ENCRYPTED config (generated by setup.html),
# it is safe to do so — run:  git add -f config.js
# Encrypted config contains only ciphertext; passphrase stays with you.
config.js

